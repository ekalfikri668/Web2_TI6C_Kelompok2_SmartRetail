{
    "info": {
        "name": "LaptopStore Mini Retail REST API Collection",
        "description": "Koleksi Postman REST API untuk aplikasi Mini Retail (LaptopStore) dengan otentikasi JWT dan validasi error JSON kustom.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Autentikasi",
            "item": [
                {
                    "name": "Registrasi Pembeli Baru",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nama_pembeli\": \"Budi Santoso\",\n  \"email\": \"budi@gmail.com\",\n  \"password\": \"budi123\",\n  \"no_hp\": \"081234567890\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "register"
                            ]
                        },
                        "description": "Mendaftarkan akun pembeli baru ke database dengan password terenkripsi."
                    }
                },
                {
                    "name": "Login Akun",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if(jsonData.success && jsonData.data.token){",
                                    "    pm.environment.set(\"jwt_token\", jsonData.data.token);",
                                    "    pm.collectionVariables.set(\"jwt_token\", jsonData.data.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"budi@gmail.com\",\n  \"password\": \"budi123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "login"
                            ]
                        },
                        "description": "Login akun (pembeli atau admin) untuk mendapatkan token JWT."
                    }
                }
            ]
        },
